// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  username  String    @unique
  password  String
  avatar    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  entries   Entry[]
  tags      Tag[]
  settings  UserSettings?
}

model UserSettings {
  id                String   @id @default(uuid())
  userId            String   @unique
  theme             String   @default("light")
  defaultPrivacy    Privacy  @default(PRIVATE)
  emailNotifications Boolean @default(true)
  dailyReminder     Boolean  @default(false)
  reminderTime      String?  // Format: "HH:MM"
  language          String   @default("en")
  timezone          String   @default("UTC")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Entry {
  id          String    @id @default(uuid())
  userId      String
  title       String?
  content     String
  mood        Mood?
  privacy     Privacy   @default(PRIVATE)
  location    String?
  weather     String?
  wordCount   Int       @default(0)
  isFavorite  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags        EntryTag[]
  attachments Attachment[]
  
  @@index([userId, createdAt])
  @@index([userId, mood])
}

model Tag {
  id        String    @id @default(uuid())
  name      String
  color     String?
  userId    String
  category  TagCategory @default(KEYWORD)
  createdAt DateTime  @default(now())
  
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries   EntryTag[]
  
  @@unique([name, userId])
  @@index([userId])
  @@index([category])
}

model EntryTag {
  id         String   @id @default(uuid())
  entryId    String
  tagId      String
  confidence Float    @default(1.0)
  autoGenerated Boolean @default(false)
  createdAt  DateTime @default(now())
  
  entry      Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@unique([entryId, tagId])
  @@index([entryId])
  @@index([tagId])
}

model Attachment {
  id        String   @id @default(uuid())
  entryId   String
  type      AttachmentType
  url       String
  filename  String
  size      Int
  mimeType  String?
  createdAt DateTime @default(now())
  
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  
  @@index([entryId])
}

enum Mood {
  HAPPY
  SAD
  EXCITED
  ANXIOUS
  CALM
  ANGRY
  GRATEFUL
  CONFUSED
  HOPEFUL
  TIRED
  ENERGETIC
  NEUTRAL
}

enum Privacy {
  PRIVATE
  PUBLIC
  FRIENDS
}

enum AttachmentType {
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
}

enum TagCategory {
  EMOTION
  PERSON
  PLACE
  TOPIC
  KEYWORD
  ACTIVITY
  EVENT
  ORGANIZATION
}

model NLPAnalysisCache {
  id        String   @id @default(uuid())
  textHash  String   @unique
  language  String   @default("en")
  analysis  Json
  createdAt DateTime @default(now())
  expiresAt DateTime
  
  @@index([textHash])
  @@index([expiresAt])
}