# Application Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
DATABASE_URL=postgresql://diary_user:your_secure_password@localhost:5432/daily_thoughts
# JWT Configuration
# Generate secure random secrets using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_use_at_least_64_characters
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_use_at_least_64_characters
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Logging
LOG_DIR=logs
LOG_LEVEL=info
LOG_QUERIES=false

# Email Configuration (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@dailythoughts.com

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:5173

# Backup Configuration
BACKUP_HOUR=2
BACKUP_MINUTE=0
BACKUP_RETENTION_DAYS=30

# Database Optimization
OPTIMIZE_DAY_OF_WEEK=0
OPTIMIZE_HOUR=3

# NLP Configuration
NLP_CACHE_TTL=3600000
NLP_MAX_CACHE_SIZE=1000

# Security
BCRYPT_ROUNDS=10
SESSION_SECRET=your_session_secret_here_use_at_least_32_characters

# External APIs (if needed)
WEATHER_API_KEY=your-weather-api-key
GEOCODING_API_KEY=your-geocoding-api-key